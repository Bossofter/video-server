{
    "name": "video-server",
    "version-string": "1.1.1",
    "description": "Portable C++ video streaming subsystem",
    "dependencies": [
        {
            "name": "vcpkg-cmake",
            "host": true
        },
        {
            "name": "vcpkg-cmake-config",
            "host": true
        },
        {
            "name": "ffmpeg",
            "features": [
                "openh264"
            ]
        },
        {
            "name": "libdatachannel",
            "features": [
                "srtp"
            ]
        },
        "libjuice",
        "openssl",
        "libsrtp",
        "spdlog",
        "tomlplusplus"
    ]
}
